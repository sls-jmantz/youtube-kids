{
  "name": "approved-tube-kids",
  "version": "0.1.0",
  "private": true,
  "description": "A cross-platform approved-channel YouTube viewer for kids.",
  "author": {
    "name": "sls-jmantz",
    "email": "sls-jmantz@users.noreply.github.com"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "predev": "node scripts/check-linux-deps.cjs",
    "electron:install": "node node_modules/electron/install.js",
    "icons": "node scripts/generate-icons.cjs",
    "build": "vite build",
    "postbuild": "node scripts/check-built-app.cjs",
    "test": "node --test",
    "start": "npm run build && electron . --load-dist",
    "prestart": "node scripts/check-linux-deps.cjs",
    "prepackage:linux": "npm run icons && npm run build",
    "package:linux": "electron-builder --linux AppImage",
    "prepackage:linux:deb": "npm run icons && npm run build",
    "package:linux:deb": "electron-builder --linux deb",
    "prepackage:windows": "npm run icons && npm run build",
    "package:windows": "electron-builder --win nsis"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "vite": "8.1.3",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "local.approved-tube-kids.app",
    "productName": "Approved Tube Kids",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "copyright": "Copyright (c) 2026 sls-jmantz",
    "icon": "build/icon",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "category": "Education",
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
